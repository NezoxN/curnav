{
  "name": "ibkt-backend",
  "version": "1.0.0",
  "description": "iBKT Individual Educational Trajectories — Express.js backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --poll --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma --accept-data-loss",
    "db:flush": "node flush-db.js",
    "db:studio": "prisma studio",
    "db:seed": "ts-node -P prisma/tsconfig.json prisma/seed.ts",
    "seed": "ts-node -P prisma/tsconfig.json prisma/seed.ts",
    "python:start": "python -m uvicorn server:app --reload --port 8000 --app-dir analytical_core"
  },
  "prisma": {
    "seed": "ts-node -P prisma/tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pm2": "^7.0.1",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.8",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^7.7.0",
    "prisma-dbml-generator": "^0.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "glob": "^13.0.6",
    "rimraf": "^6.1.3",
    "uuid": "^14.0.0",
    "tar": "^7.5.15",
    "ts-node-dev": {
      "rimraf": "^3.0.2"
    },
    "prisma-dbml-generator": {
      "glob": "7.2.3",
      "rimraf": "3.0.2"
    },
    "cross-spawn": "^7.0.6",
    "tmp": "^0.2.5",
    "@hono/node-server": "^1.19.14"
  }
}
